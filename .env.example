DISCORD_TOKEN=your-bot-token-here
PREFIX=!

# All values below default to MeadBot's original home server (The Mead Hall) if omitted.
# Override them to run the bot on a different server.

# channel IDs
ADMIN_BOT_SPAM_CHANNEL_ID=
BOT_SPAM_CHANNEL_ID=
THUNDERDOME_CHANNEL_ID=
SUGGESTIONS_CHANNEL_ID=
# leave empty to disable the honeypot auto-ban moderation feature
HONEYPOT_CHANNEL_ID=
# comma-separated list of channel IDs where MeadBot banters back when mentioned
BANTER_CHANNEL_IDS=

# guild ID
MEAD_HALL_GUILD_ID=

# role config
HONEYPOT_EXEMPT_ROLE_ID=
TROLL_ROLE_NAME=Troll

# bot owner (receives DMs on unhandled command errors)
BOT_OWNER_USER_ID=
BOT_OWNER_SEARCH_QUERY=

# easter-egg user IDs
EASTER_EGG_USER_YEAH=
# comma-separated list
EASTER_EGG_USERS_REACT=

# custom guild emoji IDs used by passive reactions
EMOJI_CHILI_BEAN=
EMOJI_CHILI_NO_BEAN=
EMOJI_RAISIN=
EMOJI_TEXAS=
EMOJI_MINNESOTA=
EMOJI_CHICAGO=
EMOJI_EASTER_EGG_REACT=

# content links
DOCUMENTATION_URL=
MONK_IMAGE_URL=
PADDLIN_IMAGE_URL=
FUNDING_URL=

# how often (ms) the old-message cleanup job runs; defaults to 24 hours
CLEANUP_INTERVAL_MS=
